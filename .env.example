# AVE SAGE — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env to git.

# ── AVE Cloud API (required) ──────────────────────────────────────────────────
# Get these from https://cloud.ave.ai → Settings → API Keys
AVE_API_KEY=your_ave_api_key_here
AVE_SECRET_KEY=your_ave_secret_key_here
API_PLAN=free

# ── AVE Proxy Wallet (required for live trading) ──────────────────────────────
# Run: python scripts/create_wallet.py  → copy the returned assetsId and address here
PROXY_ASSETS_ID=your_proxy_assets_id_here
PROXY_WALLET_ADDRESS=your_solana_wallet_address_here

# ── LLM via OpenRouter (required) ────────────────────────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here
# Model to use — browse at https://openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-sonnet-4-20250514

# ── OpenAI (optional) ─────────────────────────────────────────────────────────
# Only needed if you switch embedding_provider to "openai" in config.yaml
OPENAI_API_KEY=

# ── Telegram Bot (optional) ───────────────────────────────────────────────────
# Create a bot at https://t.me/BotFather, get your chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_ID=your_telegram_user_id_here

# ── macOS SSL fix (only needed locally on macOS) ──────────────────────────────
# Run once: pip install certifi — then uncomment and set the paths below
# SSL_CERT_FILE=/path/to/.venv/lib/python3.12/site-packages/certifi/cacert.pem
# REQUESTS_CA_BUNDLE=/path/to/.venv/lib/python3.12/site-packages/certifi/cacert.pem
